  "records": {
    "description": "This cart yeeter supports stacked carts as input.",
    "features": [
      "Stacked cart compatible",
      "Outputs inventory items and cart items separately in item entity form"
    ],
    "notes": "The cart item has enough rightwards momentum that you can replace the glass block next to the cauldron with soul sand, and bubble column the cart item up directly.",
    "instructions": [
      "You must use a chest or ender chest block, it's the only hitbox that works reliably.",
      "The stacked carts must be locked with an activator rail before yeeting. otherwise they can pick up items and result in carts leaking to item output.",
      "The wall must be flat without a middle post for proper cart alignment"
    ]
  },
