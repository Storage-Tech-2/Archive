  "records": {
    "description": "This cart yeeter yeets stacked carts and perfectly aligns the item output such that they merge into full stacks perfectly. Works similar to CT001 but is compatible with stacked carts.",
    "features": [
      "Stacked cart compatible",
      "Outputs cart's contents in item entity form, aligned in all axis + time.",
      "Items output are perfectly merged; not broken up into smaller stacks.",
      "Preserves and outputs cart items into a separate output"
    ],
    "considerations": [
      "Can't be clocked very fast,  24gt minimum clock cycle recommended"
    ],
    "notes": "Tested for 500k item entities using <@458048759247536128> , <@921904275418927214> , and Crec0's alignment logging scarpet script"
  },
