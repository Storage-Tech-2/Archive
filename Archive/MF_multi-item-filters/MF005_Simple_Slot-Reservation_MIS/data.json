  "records": {
    "description": "Multi-Item Sorter using slot reservation method. The storage chests themselves are the filters. The device itself is very simple: it tries pushing items you input into a storage chest. If it doesn't fit, it tries the next.",
    "features": [
      "Slot Reservation",
      "2wt horizontally",
      "1wABt vertically",
      "10gt global clock cycle (per item)"
    ],
    "considerations": [
      "Need to adjust timer in global clock if modifying size",
      "Must leave one item in the slot (don't take out full stack) or that slot will fill up with the whatever item that comes."
    ],
    "compatibility": "1.5+"
  },
