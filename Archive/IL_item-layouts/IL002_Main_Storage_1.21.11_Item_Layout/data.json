  "records": {
    "description": "Based on Yams v2.3 Item Layout.\nA reworked layout that aims to add missing things, but tries to keep the original in mind",
    "features": [
      "1 bulk hall",
      "2 chest halls",
      "16 MIS Categories"
    ],
    "exceptions": "- Bee Nests\n- Player and mob heads\n- Dragon eggs\n- Suspicious gravel/sand\n- Ominous trial keys\n- Heavy cores",
    "additions-compared-to-original": "- Bamboo and its variants\n- Lightning rods and their variants\n- Copper golems and their variants\n- Pressure plates and buttons\n- Paintings\n- Rotten Flesh\n- Tipped arrows",
    "notes": "The schematic contains both a plane and a spinal version. The skeletal spine version represents Yams v2 filters.",
    "compatibility": "1.21.11+"
  },
