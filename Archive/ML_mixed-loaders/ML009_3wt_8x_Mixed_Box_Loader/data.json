  "records": {
    "description": "Loads single or mixed item types into shulker boxes at 8x hopper speed (approximately 72k/hr)",
    "features": [
      "Small (5x7x3)",
      "No item spitting with random input",
      "Locally clocked",
      "Outputs boxes into a global hopperline"
    ],
    "considerations": [
      "No ice blocks in the item stream, making it not that Nether friendly",
      "Can buffer items inside the droppers"
    ],
    "compatibility": "1.13+. For Minecraft 1.13 compatibility, use droppers instead of composters."
  },
