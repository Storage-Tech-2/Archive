  "records": {
    "description": "This variable item processor sorts item entities into ideal output split boxes. This is an adjustment to the original system by <@688456529338433611> to make it work in newer versions of the game, removing overstacked items in the filters and fixing the dolphin cage.",
    "features": [
      "input: item entity pile, empty boxes",
      "output: single item type boxes, unstackable items",
      "auto starts when items stop coming in",
      "uses variable stack separation based filters",
      "includes dolphin for item entity despawn protection",
      "no more overstacked items",
      "fixed the dolphin cage"
    ],
    "considerations": [
      "empty box line may need rework"
    ],
    "compatibility": "older version for below MC 1.21: https://discord.com/channels/748542142347083868/749137424684285992/1107706303155019897"
  },
